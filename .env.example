# Phase 17.7a：LLM 服务端执行
# 将本文件复制为 .env 或 .env.local，并填入真实密钥
# 密钥仅由服务端使用，不会暴露到前端

# ─── 服务器 ───────────────────────────────
PORT=3001
NODE_ENV=development

# ─── 数据库 ───────────────────────────────
DATABASE_URL=file:./server/data/app.db
# 生产推荐 PostgreSQL:
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── LLM ──────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key
# 可选：LLM API 服务端口，默认 3001
# LLM_API_PORT=3001

# ─── Facebook 公共主页授权 ─────────────────────────────────────────────────────
# FACEBOOK_APP_ID=你的应用编号
# FACEBOOK_APP_SECRET=你的应用密钥
# 可选：不填则服务端按当前请求域名自动生成回调地址
# FACEBOOK_REDIRECT_URI=https://your-domain.com/api/facebook/auth/callback
# 可选：不填则服务端按当前请求域名跳转到 /tenant/facebook-pages
# FACEBOOK_FRONTEND_REDIRECT=https://your-domain.com/tenant/facebook-pages

# ─── 认证（迭代五接入后启用）─────────────
# JWT_SECRET=your-jwt-secret
# JWT_EXPIRES_IN=7d
