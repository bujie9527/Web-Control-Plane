{
  "name": "ai-work-control-center",
  "version": "0.0.1",
  "private": true,
  "description": "AI Work Control Center - 企业级 AI 工作中控后台",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "tsx watch server/index.ts",
    "dev:full": "concurrently \"npm run dev\" \"npm run dev:api\"",
    "start": "vite",
    "build": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "preview": "vite preview",
    "start:prod": "node dist-server/index.js",
    "db:migrate:prod": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "typecheck": "tsc --noEmit",
    "lint": "npm run lint:src && npm run lint:server",
    "lint:src": "eslint \"src/**/*.{ts,tsx}\"",
    "lint:server": "eslint \"server/**/*.ts\"",
    "lint:fix": "npm run lint:fix:src && npm run lint:fix:server",
    "lint:fix:src": "eslint \"src/**/*.{ts,tsx}\" --fix",
    "lint:fix:server": "eslint \"server/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\" \"server/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\" \"server/**/*.ts\"",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "docs:log": "node scripts/docs-log-changes.mjs",
    "docs:index": "node scripts/docs-sync-index.mjs",
    "docs:update": "node scripts/docs-log-changes.mjs && node scripts/docs-sync-index.mjs"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@xyflow/react": "^12.10.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "cron-parser": "^5.5.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.577.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.71.2",
    "react-router-dom": "^6.28.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@prisma/client": "^6.19.2",
    "@tailwindcss/vite": "^4.2.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.0.1",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "prettier": "^3.3.0",
    "prisma": "^6.19.2",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.19.0",
    "typescript": "~5.6.2",
    "vite": "^6.0.1"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
